# Copy this file to .env and fill only the keys for the providers you use.
# Model selection lives in squad.toml, or you can override all seats with:
#   python cli.py --sample --provider groq --model llama-3.1-8b-instant

# Default config uses Groq for all three agents.
GROQ_API_KEY=

# Optional extra providers.
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: needed only for private PRs or to avoid public GitHub API limits.
GITHUB_TOKEN=