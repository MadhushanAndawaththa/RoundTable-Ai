# Gemini API key - get a FREE key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GitHub Personal Access Token for fetching private PR diffs or avoiding rate limits
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Optional: model name (defaults to gemini-2.0-flash - free tier)
GEMINI_MODEL=gemini-2.0-flash
